generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String? @map("refresh_token")
  access_token       String? @map("access_token")
  expires_at         Int?    @map("expires_at")
  token_type         String? @map("token_type")
  scope              String?
  id_token           String? @map("id_token")
  session_state      String?
  user               User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]

  systemProfile   SystemProfile?
  visualProfile   VisualProfile?
  prospects       Prospect[]
  aiActivities    AIActivity[]
  strategicMemory StrategicMemory?
}

// ── AI Orchestration Models ──────────────────────────────────

model SystemProfile {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  servizio         String   @default("")
  clienteIdeale    String   @default("")
  problemaCliente  String   @default("")
  risultatoCliente String   @default("")
  linkedinLinks    String   @default("[]") // JSON array
  materialiNomi    String   @default("[]") // JSON array
  socialLinks      String   @default("[]") // JSON array
  tempoSettimanale String   @default("")

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// ── Visual Profile Model ──────────────────────────────────

model VisualProfile {
  id                      String   @id @default(cuid())
  userId                  String   @unique
  user                    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Color System
  primaryColor            String   @default("#3B82F6")      // Primary brand color
  secondaryColor          String   @default("#10B981")      // Secondary accent
  backgroundColor         String   @default("clean")        // visual style: clean | gradient | minimalist

  // Visual Tone & Personality
  visualTone              String   @default("professional") // professional | bold | subtle | energetic
  typographyPreset        String   @default("modern")       // modern | classic | minimal | editorial
  contentStylePersonality String   @default("founder")      // founder | corporate | consultant | educator | technical

  // Photo Strategy
  photoStrategy           String   @default("hybrid")       // real_photos | graphics | hybrid

  // Style Preset
  stylePreset             String   @default("minimal_corporate") // minimal_corporate | bold_founder | consulting_premium | educational_coach | tech_modern

  // AI Suggestions (JSON array)
  colorSuggestions        String   @default("[]")           // array of {primary, secondary, backgroundColor}
  designNotes             String   @default("")             // AI-generated insights about the user's visual preferences

  setupComplete           Boolean  @default(false)          // Has user completed visual profile setup?

  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

model Prospect {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  linkedinUrl   String   @default("")
  websiteUrl    String   @default("")
  name          String   @default("")
  role          String   @default("")
  company       String   @default("")
  sector        String   @default("")
  heatLevel     String   @default("Cold") // Cold | Warm | Hot
  priority      String   @default("low")  // high | medium | low
  summary       String   @default("")     // AI-generated summary
  lastAnalysis  String   @default("")     // JSON of last AI analysis

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  activities    AIActivity[]

  @@index([userId])
  @@unique([userId, linkedinUrl])
}

model AIActivity {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  taskType    String   // analyze_profile | find_clients | ask_advice | dm | etc.
  inputSummary String  @default("") // short summary of what was asked
  outputSummary String @default("") // short summary of response
  fullOutput  String   @default("") // JSON of full response

  prospectId  String?
  prospect    Prospect? @relation(fields: [prospectId], references: [id], onDelete: SetNull)

  createdAt   DateTime @default(now())

  @@index([userId, taskType])
  @@index([userId, createdAt])
}

model StrategicMemory {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  summary   String   @default("") // High-level strategic summary
  patterns  String   @default("") // JSON array of identified patterns
  focusArea String   @default("") // Current strategic focus

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
