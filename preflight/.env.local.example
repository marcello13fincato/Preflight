# Copy this file to .env.local and update values for local development
DASHBOARD_USER=admin
DASHBOARD_PASS=password
NEXTAUTH_SECRET=dev-secret
NEXTAUTH_URL=http://localhost:3000

# Optional: configure an admin audit token used by the marketing audit bypass UI
NEXT_PUBLIC_ADMIN_TOKEN=demo-admin-token
 
# Optional: enable Email (magic link) sign-in in production by configuring SMTP
# Example SMTP URL format: smtp://user:pass@smtp.example.com:587
EMAIL_SERVER=
EMAIL_FROM=you@example.com
# When set, also expose this flag to the client for UI toggles (only true if EMAIL_SERVER configured)
NEXT_PUBLIC_EMAIL_ENABLED=0

# --- Mailtrap example (recommended for testing) ---
# Sign up at https://mailtrap.io, create an inbox and copy SMTP settings.
# Example values (replace with your Mailtrap credentials):
# EMAIL_SERVER=smtp://<username>:<password>@smtp.mailtrap.io:2525
# EMAIL_FROM=preflight@mailtrap.local
# To enable client-side UI for magic link during development:
# NEXT_PUBLIC_EMAIL_ENABLED=1

# --- Ethereal quick test (alternative) ---
# You can also programmatically create an Ethereal account with nodemailer for local tests.
# If using Ethereal, paste the SMTP URL here after creating the account.

# --- AI (OpenAI) ---
# Required for AI-powered features. Without this key all AI routes return static default responses.
OPENAI_API_KEY=
# Optional: override the default model (default: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini
